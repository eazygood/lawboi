        <mxCell id="subtitle" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontColor=#666666;" value="Hexagonal-lite RAG: single PostgreSQL+pgvector store · fully async end-to-end · multi-turn + moderation · online API + offline ingest" vertex="1">
